{
  "manifest_version": 3,
  "name": "PhishGuard - Phishing & Spam Detector",
  "version": "1.0.0",
  "description": "AI-powered browser extension that detects phishing websites, spam emails, and suspicious text in real-time using advanced language models.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://openphish.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/default-16.png",
      "32": "icons/default-32.png",
      "48": "icons/default-48.png",
      "128": "icons/default-128.png"
    },
    "default_title": "PhishGuard"
  },
  "icons": {
    "16": "icons/default-16.png",
    "32": "icons/default-32.png",
    "48": "icons/default-48.png",
    "128": "icons/default-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["email-content.js"],
      "run_at": "document_idle"
    }
  ]
}
